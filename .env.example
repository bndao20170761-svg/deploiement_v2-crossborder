# ==================== Environment Configuration ====================
# Copy this file to .env and update with your actual values

# Spring Profile (dev, prod)
SPRING_PROFILES_ACTIVE=dev

# ==================== Public URLs (for frontend builds) ====================
# For local development
PUBLIC_URL=http://localhost:8080
FORUM_URL=http://localhost:3001
FRONTEND1_URL=http://localhost:3002
FRONTEND2_URL=http://localhost:3003

# ==================== CORS Configuration ====================
# Origines autorisées pour les requêtes CORS (séparées par des virgules)
# Pour le développement local
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002,http://127.0.0.1:3003

# ==================== Database Configuration ====================

# MongoDB (Forum Service)
MONGO_PASSWORD=admin123

# MySQL Root Password (shared)
MYSQL_ROOT_PASSWORD=root123

# MySQL User Service
MYSQL_USER_PASSWORD=user123

# MySQL Reference Service
MYSQL_REFERENCE_PASSWORD=reference123

# MySQL Patient Service
MYSQL_PATIENT_PASSWORD=patient123

# ==================== Service Ports ====================

# Gateway Port
GATEWAY_PORT=8080

# Service Registry Port
EUREKA_PORT=8761

# Config Server Port
CONFIG_SERVER_PORT=8888

# Backend Service Ports
FORUM_SERVICE_PORT=9092
USER_SERVICE_PORT=9089
REFERENCE_SERVICE_PORT=9090
PATIENT_SERVICE_PORT=9091

# Frontend Ports
FORUM_FRONT_PORT=3001
REFERENCE_FRONT_PORT=3002
USER_FRONT_PORT=3003

# Database Ports
MONGODB_PORT=27017
MYSQL_USER_PORT=3307
MYSQL_REFERENCE_PORT=3308
MYSQL_PATIENT_PORT=3309

# ==================== Security Configuration ====================

# JWT Secret (change in production)
JWT_SECRET=your-secret-key-change-in-production

# ==================== Logging Configuration ====================

# Log Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

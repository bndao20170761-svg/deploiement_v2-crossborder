# ==================== Google Cloud Platform Production Configuration ====================
# Copiez ce fichier vers .env et modifiez les valeurs selon vos besoins
# Commande: cp .env.gcp.example .env

# ==================== Spring Profile ====================
# IMPORTANT: Utilisez 'prod' pour la production
SPRING_PROFILES_ACTIVE=prod

# ==================== GCP Public URLs ====================
# IP publique de votre instance GCP
PUBLIC_IP=34.133.155.230

# URLs publiques pour les frontends (utilisées lors du build Docker)
PUBLIC_URL=http://34.133.155.230:8080
FORUM_URL=http://34.133.155.230:3001
FRONTEND1_URL=http://34.133.155.230:3002
FRONTEND2_URL=http://34.133.155.230:3003

# ==================== CORS Configuration ====================
# Origines autorisées pour les requêtes CORS (séparées par des virgules)
# Pour GCP - Ajoutez votre IP publique
CORS_ALLOWED_ORIGINS=http://34.133.155.230:3000,http://34.133.155.230:3001,http://34.133.155.230:3002,http://34.133.155.230:3003,http://34.133.155.230:8080

# ==================== Database Configuration ====================

# MongoDB (Forum Service)
# Changez ce mot de passe par un mot de passe sécurisé
MONGO_PASSWORD=MongoSecure2024!ChangeMe

# MySQL Root Password (partagé par toutes les bases MySQL)
# Changez ce mot de passe par un mot de passe sécurisé
MYSQL_ROOT_PASSWORD=RootSecure2024!ChangeMe

# MySQL User Service
# Changez ce mot de passe par un mot de passe sécurisé
MYSQL_USER_PASSWORD=UserSecure2024!ChangeMe

# MySQL Reference Service
# Changez ce mot de passe par un mot de passe sécurisé
MYSQL_REFERENCE_PASSWORD=ReferenceSecure2024!ChangeMe

# MySQL Patient Service
# Changez ce mot de passe par un mot de passe sécurisé
MYSQL_PATIENT_PASSWORD=PatientSecure2024!ChangeMe

# ==================== Security Configuration ====================

# JWT Secret (TRÈS IMPORTANT - même clé pour tous les services)
# Utilisation de la clé existante depuis GitHub pour cohérence
JWT_SECRET=hF9IsSdyj/KnkZiAJsAnwKsf4rJombf3MAX4pZFBzql8WQyPFy8gVSGxUyTaT3m4gE9yG+i1KGz5BpP5k8+jgg==

# ==================== GCP Configuration ====================

# IP publique de votre instance GCP
# Sera détectée automatiquement par le script de déploiement
PUBLIC_IP=34.133.155.230

# ==================== Logging Configuration ====================

# Log Level (INFO pour production, DEBUG pour développement)
LOG_LEVEL=INFO

# ==================== Service Ports (Ne pas modifier) ====================

# Gateway Port
GATEWAY_PORT=8080

# Service Registry Port
EUREKA_PORT=8761

# Config Server Port
CONFIG_SERVER_PORT=8888

# Backend Service Ports
FORUM_SERVICE_PORT=9092
USER_SERVICE_PORT=9089
REFERENCE_SERVICE_PORT=9090
PATIENT_SERVICE_PORT=9091

# Frontend Ports
FORUM_FRONT_PORT=3001
REFERENCE_FRONT_PORT=3002
USER_FRONT_PORT=3003

# Database Ports
MONGODB_PORT=27017
MYSQL_USER_PORT=3307
MYSQL_REFERENCE_PORT=3308
MYSQL_PATIENT_PORT=3309

# ==================== Notes ====================
# 
# 1. SÉCURITÉ:
#    - Changez TOUS les mots de passe par des valeurs sécurisées
#    - Utilisez des mots de passe différents pour chaque service
#    - Minimum 12 caractères avec majuscules, minuscules, chiffres et symboles
#
# 2. JWT_SECRET:
#    - Doit être identique sur tous les services
#    - Minimum 64 caractères recommandé
#    - Ne partagez JAMAIS cette clé
#
# 3. PRODUCTION:
#    - Utilisez SPRING_PROFILES_ACTIVE=prod
#    - Activez LOG_LEVEL=INFO ou WARN
#    - Sauvegardez ce fichier en lieu sûr
#
# 4. GÉNÉRATION DE MOTS DE PASSE SÉCURISÉS:
#    openssl rand -base64 32
#
# 5. GOOGLE CLOUD PLATFORM:
#    - Assurez-vous que les règles de pare-feu sont configurées
#    - Ports à ouvrir: 8080, 3001, 3002, 3003
#    - Vérifiez que votre VM a suffisamment de ressources (minimum 2 vCPU, 4 GB RAM)
#

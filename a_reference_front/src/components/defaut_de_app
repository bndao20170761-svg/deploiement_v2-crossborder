            hospital.latitude.toFixed(6) !== userLocation.lat.toFixed(6) ||
            hospital.longitude.toFixed(6) !== userLocation.lng.toFixed(6)
          )
        )
        .map((hospital) => (
          <Marker
            key={hospital.id}
            position={{
              lat: hospital.latitude || hospital.lat || defaultCenter.lat,
              lng: hospital.longitude || hospital.lng || defaultCenter.lng
            }}
            icon={ICONS.confirmed}
            onClick={() => {
              setSelectedHospital(hospital);
              setShowUserInfo(false);
            }}
          />
        ))
      }

      {/* Hôpitaux en attente (violet) - EXCLUT la position utilisateur */}
      {hospitals
        .filter(hospital => !hospital.active)
        .filter(hospital =>
          !userLocation || (
            hospital.latitude.toFixed(6) !== userLocation.lat.toFixed(6) ||
            hospital.longitude.toFixed(6) !== userLocation.lng.toFixed(6)
          )
        )
        .map((hospital) => (
          <Marker
            key={hospital.id}
            position={{
              lat: hospital.latitude || hospital.lat || defaultCenter.lat,
              lng: hospital.longitude || hospital.lng || defaultCenter.lng
            }}
            icon={ICONS.pending}
            onClick={() => {
              setSelectedHospital(hospital);
              setShowUserInfo(false);
            }}
          />
        ))
      }

      {/* Position utilisateur - AFFICHE les hôpitaux à cette position */}
      {userLocation && (
        <>
          <Marker
            position={userLocation}
            icon={{
              url: `http://maps.google.com/mapfiles/ms/icons/${userMarkerColor}-dot.png`,
              scaledSize: { width: 40, height: 40 }
            }}
            title={userMarkerColor === "red" ? "Hôpital existant" : "Votre position"}
            onClick={() => {
              // Vérifie s'il existe un hôpital (actif OU inactif) à cette position
              const hospitalHere = hospitals.find(
                h =>
                  h.latitude.toFixed(6) === userLocation.lat.toFixed(6) &&
                  h.longitude.toFixed(6) === userLocation.lng.toFixed(6)
              );

              if (hospitalHere) {
                // S'il y a un hôpital, afficher ses détails
                setSelectedHospital(hospitalHere);
                setShowUserInfo(false);
              } else {
                // Sinon, proposer d'ajouter un établissement
                setShowUserInfo(true);
                setSelectedHospital(null);
              }
            }}
          />

          {/* InfoWindow pour ajout */}
          {showUserInfo && (
            <InfoWindow
              position={userLocation}
              onCloseClick={() => setShowUserInfo(false)}
            >
              <Box sx={{ p: 1, minWidth: 200 }}>
                <Typography variant="body2" fontWeight="bold">📍 Votre position</Typography>
                <Button
                  variant="contained"
                  size="small"
                  fullWidth
                  sx={{ mt: 1 }}
                  startIcon={<AddLocation />}
                  onClick={handleAddAtUserLocation}
                >
                  Ajouter un établissement ici
                </Button>
              </Box>
            </InfoWindow>
          )}
        </>
      )}

      {/* Position cliquée */}
      {clickedPosition && (
        <Marker
          position={clickedPosition}
          icon={ICONS.current}
          title="Emplacement sélectionné pour ajout"
        />
      )}

      {/* InfoWindow pour hôpital sélectionné */}
      {selectedHospital && (
        <InfoWindow
          position={{
            lat: selectedHospital.latitude || selectedHospital.lat || defaultCenter.lat,
            lng: selectedHospital.longitude || selectedHospital.lng || defaultCenter.lng
          }}
          onCloseClick={() => setSelectedHospital(null)}
        >
          <Box sx={{ minWidth: 300, p: 1 }}>
            <Typography variant="h6" gutterBottom>
              <LocalHospital sx={{ mr: 1 }} />
              {selectedHospital.nom}
            </Typography>

            <Typography variant="body2" color="text.secondary" gutterBottom>
              {selectedHospital.description || 'Aucune description'}
            </Typography>

            <Box sx={{ mt: 1 }}>
              <Chip
                label={selectedHospital.active ? 'Actif' : 'En attente'}
                size="small"
                color={selectedHospital.active ? 'success' : 'warning'}
              />
              <Typography variant="body2" sx={{ mt: 1 }}>
                📍 {selectedHospital.ville}, {selectedHospital.pays}
              </Typography>
              {selectedHospital.telephoneFixe && (
                <Typography variant="body2">
                  📞 {selectedHospital.telephoneFixe}
                </Typography>
              )}
              <Typography variant="caption" display="block" sx={{ mt: 1, color: 'text.secondary' }}>
                Coordonnées: {selectedHospital.latitude?.toFixed(6)}, {selectedHospital.longitude?.toFixed(6)}
              </Typography>
            </Box>
          </Box>
        </InfoWindow>
      )}

    </GoogleMap>
  </LoadScript>



                         let value = e.target.value.replace(/[^\d+]/g, '');

                         // Formatage automatique pour le Sénégal
                         if (value.startsWith('+221')) {
                           value = value.replace(/^(\+221)(\d{2})(\d{3})(\d{2})(\d{2})$/, '$1 $2 $3 $4 $5');
                         }
                         // Formatage pour la Gambie
                         else if (value.startsWith('+220')) {
                           value = value.replace(/^(\+220)(\d{3})(\d{4})$/, '$1 $2 $3');
                         }
                         // Formatage pour la Guinée-Bissau
                         else if (value.startsWith('+245')) {
                           value = value.replace(/^(\+245)(\d{3})(\d{4})$/, '$1 $2 $3');
                         }

                         handleFormChange('telephoneFixe', value);
                       }}

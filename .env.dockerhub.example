# Configuration pour le déploiement depuis Docker Hub
# Copiez ce fichier vers .env et remplissez les valeurs

# ==================== Docker Hub ====================
# Votre username Docker Hub (REQUIS)
DOCKERHUB_USERNAME=votre-username

# ==================== Database Passwords ====================
# MongoDB
MONGO_PASSWORD=admin123

# MySQL Root
MYSQL_ROOT_PASSWORD=root123

# MySQL Services
MYSQL_USER_PASSWORD=user123
MYSQL_REFERENCE_PASSWORD=reference123
MYSQL_PATIENT_PASSWORD=patient123

# ==================== Spring Configuration ====================
# Profile actif (dev, prod)
SPRING_PROFILES_ACTIVE=dev
